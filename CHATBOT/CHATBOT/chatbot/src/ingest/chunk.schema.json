{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chatbot.local/schemas/chunk.schema.json",
  "title": "Admission Chunk",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "chunk_id",
    "doc_id",
    "chunk_index",
    "chunk_text",
    "token_count",
    "source_url",
    "school_code",
    "intake_year",
    "document_type",
    "admission_method",
    "major_codes",
    "major_names",
    "faculty",
    "degree_level",
    "training_form",
    "subject_groups",
    "campus",
    "deadline_type",
    "deadline_date",
    "fee_min",
    "fee_max",
    "fee_unit",
    "required_documents",
    "target_audience",
    "citations",
    "quality_flags"
  ],
  "properties": {
    "chunk_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Z0-9-]+$"
    },
    "doc_id": {
      "type": "string",
      "minLength": 1
    },
    "chunk_index": {
      "type": "integer",
      "minimum": 0
    },
    "chunk_text": {
      "type": "string",
      "minLength": 30
    },
    "token_count": {
      "type": "integer",
      "minimum": 1
    },
    "source_url": {
      "type": "string",
      "format": "uri"
    },
    "school_code": {
      "type": "string",
      "minLength": 2
    },
    "intake_year": {
      "type": "integer",
      "minimum": 2000,
      "maximum": 2100
    },
    "document_type": {
      "type": "string",
      "minLength": 1
    },
    "admission_method": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "hoc_ba",
          "diem_thi_thpt",
          "danh_gia_nang_luc"
        ]
      },
      "uniqueItems": true
    },
    "major_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^7\\d{6}$"
      },
      "uniqueItems": true
    },
    "major_names": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9_]+$"
      },
      "uniqueItems": true
    },
    "faculty": {
      "type": [
        "string",
        "null"
      ]
    },
    "degree_level": {
      "type": "string"
    },
    "training_form": {
      "type": "string"
    },
    "subject_groups": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^(A|D)\\d{2}$"
      },
      "uniqueItems": true
    },
    "campus": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "deadline_type": {
      "type": [
        "string",
        "null"
      ]
    },
    "deadline_date": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "fee_min": {
      "type": [
        "number",
        "null"
      ]
    },
    "fee_max": {
      "type": [
        "number",
        "null"
      ]
    },
    "fee_unit": {
      "type": "string"
    },
    "required_documents": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "target_audience": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "citations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source_url",
          "source_name"
        ],
        "properties": {
          "source_url": {
            "type": "string",
            "format": "uri"
          },
          "source_name": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "quality_flags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    }
  }
}